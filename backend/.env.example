PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
# Production example:
# FRONTEND_URL=https://your-site.netlify.app
# Multiple origins (comma-separated) are supported:
# FRONTEND_URL=https://your-site.netlify.app,https://www.yourdomain.com

# Use any one of these MongoDB keys. Backend checks in this order:
# MongoDB_URL -> MONGODB_URL -> MONGO_URI
MONGODB_URL=mongodb+srv://<user>:<password>@<cluster>/<db>

JWT_SECRET=replace-with-strong-random-secret
SESSION_SECRET=replace-with-strong-random-secret

CLOUD_NAME=your-cloudinary-cloud-name
CLOUD_API_KEY=your-cloudinary-api-key
CLOUD_API_SECRET=your-cloudinary-api-secret

ENABLE_REQUEST_LOGS=false
